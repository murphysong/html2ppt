{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/slides.schema.json",
  "title": "PPT Slides Specification",
  "type": "object",
  "required": ["meta", "slides"],
  "additionalProperties": false,
  "properties": {
    "meta": {
      "type": "object",
      "required": ["project_name", "version"],
      "additionalProperties": false,
      "properties": {
        "project_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "author": { "type": "string" },
        "language": { "type": "string", "default": "zh-CN" },
        "default_page_type": {
          "type": "string",
          "enum": [
            "overview_cards",
            "compare_2col",
            "timeline",
            "left_text_right_image",
            "conclusion",
            "cover",
            "toc",
            "free_layout"
          ]
        },
        "notes": { "type": "string" }
      }
    },

    "slides": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/slide" }
    }
  },

  "$defs": {
    "slide": {
      "type": "object",
      "required": ["page_id", "page_type"],
      "additionalProperties": false,
      "properties": {
        "page_id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9_\\-]+$"
        },
        "page_type": {
          "type": "string",
          "enum": [
            "cover",
            "toc",
            "overview_cards",
            "compare_2col",
            "timeline",
            "left_text_right_image",
            "conclusion",
            "free_layout"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "prototype_checked",
            "approved",
            "needs_revision"
          ],
          "default": "draft"
        },
        "content": { "$ref": "#/$defs/content" },
        "layout": { "$ref": "#/$defs/layout" },
        "overrides": { "$ref": "#/$defs/overrides" },
        "visual": { "$ref": "#/$defs/visual" },
        "assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/asset" }
        },
        "render": {
          "type": "object",
          "required": ["mode"],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["template_auto", "absolute_elements"]
            },
            "elements": {
              "type": "array",
              "items": { "$ref": "#/$defs/renderElement" }
            },
            "diagnostics": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },
        "notes": { "type": "string" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "page_type": { "const": "free_layout" } }
          },
          "then": {
            "required": ["render"]
          }
        },
        {
          "if": {
            "properties": {
              "page_type": {
                "enum": [
                  "cover",
                  "toc",
                  "overview_cards",
                  "compare_2col",
                  "timeline",
                  "left_text_right_image",
                  "conclusion"
                ]
              }
            }
          },
          "then": {
            "required": ["content"]
          }
        }
      ]
    },

    "content": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 60 },
        "subtitle": { "type": "string", "maxLength": 100 },
        "tag": { "type": "string", "maxLength": 20 },

        "core_statement": { "type": "string", "maxLength": 80 },
        "core_support_1": { "type": "string", "maxLength": 100 },
        "core_support_2": { "type": "string", "maxLength": 100 },

        "left_title": { "type": "string", "maxLength": 30 },
        "right_title": { "type": "string", "maxLength": 30 },

        "left_points": {
          "type": "array",
          "items": { "type": "string", "maxLength": 80 },
          "maxItems": 8
        },
        "right_points": {
          "type": "array",
          "items": { "type": "string", "maxLength": 80 },
          "maxItems": 8
        },

        "bullets": {
          "type": "array",
          "items": { "type": "string", "maxLength": 100 },
          "maxItems": 10
        },

        "cards": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/card" }
        },

        "timeline_items": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/timelineItem" }
        },

        "image_caption": { "type": "string", "maxLength": 80 },
        "footer": { "type": "string", "maxLength": 80 }
      }
    },

    "card": {
      "type": "object",
      "required": ["title"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "maxLength": 30 },
        "subtitle": { "type": "string", "maxLength": 60 },
        "icon": { "type": "string", "maxLength": 40 },
        "emphasis": {
          "type": "string",
          "enum": ["normal", "strong", "weak"],
          "default": "normal"
        }
      }
    },

    "timelineItem": {
      "type": "object",
      "required": ["label", "title"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "maxLength": 20 },
        "title": { "type": "string", "maxLength": 30 },
        "description": { "type": "string", "maxLength": 80 }
      }
    },

    "layout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "variant": { "type": "string", "maxLength": 30 },
        "density": {
          "type": "string",
          "enum": ["airy", "normal", "compact"],
          "default": "normal"
        },
        "hero_box": {
          "type": "string",
          "enum": ["none", "compact", "normal", "large"],
          "default": "normal"
        },
        "card_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 8
        },
        "card_style": {
          "type": "string",
          "enum": [
            "auto",
            "2x2",
            "1x3",
            "1x4",
            "2x3",
            "horizontal",
            "vertical"
          ],
          "default": "auto"
        },
        "show_tag": { "type": "boolean", "default": true },
        "show_footer": { "type": "boolean", "default": true },
        "title_lines": { "type": "integer", "minimum": 1, "maximum": 4 },
        "align_mode": {
          "type": "string",
          "enum": ["balanced", "text_heavy", "visual_heavy"],
          "default": "balanced"
        },
        "section_emphasis": {
          "type": "string",
          "enum": ["title", "hero", "cards", "image", "footer"],
          "default": "hero"
        }
      }
    },

    "overrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title_width": { "type": "number", "minimum": 1 },
        "title_height": { "type": "number", "minimum": 0.1 },
        "hero_box_height": { "type": "number", "minimum": 0.1 },
        "card_area_top": { "type": "number", "minimum": 0 },
        "card_area_height": { "type": "number", "minimum": 0.1 },
        "footer_top": { "type": "number", "minimum": 0 },
        "image_box_width": { "type": "number", "minimum": 0.1 },
        "image_box_height": { "type": "number", "minimum": 0.1 },
        "font_scale": {
          "type": "number",
          "minimum": 0.5,
          "maximum": 2.0
        },
        "custom": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },

    "visual": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "text_only",
            "icon_only",
            "optional_visual",
            "diagram_needed",
            "photo_needed",
            "background_needed",
            "image_required"
          ],
          "default": "text_only"
        },
        "image_position": {
          "type": "string",
          "enum": ["none", "left", "right", "top", "bottom", "background", "center"],
          "default": "none"
        },
        "image_ratio": {
          "type": "string",
          "enum": ["wide", "square", "tall", "auto"],
          "default": "auto"
        },
        "image_style": {
          "type": "string",
          "enum": ["realistic", "illustration", "diagram", "flat_icon", "abstract_tech"]
        },
        "visual_priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "default": "medium"
        }
      }
    },

    "asset": {
      "type": "object",
      "required": ["role", "source_type"],
      "additionalProperties": false,
      "properties": {
        "role": {
          "type": "string",
          "enum": ["background", "main_image", "side_image", "icon_set", "diagram", "logo"]
        },
        "source_type": {
          "type": "string",
          "enum": ["generated", "retrieved", "manual", "local_file"]
        },
        "path": { "type": "string" },
        "prompt": { "type": "string" },
        "query": { "type": "string" },
        "notes": { "type": "string" }
      }
    },

    "renderElement": {
      "type": "object",
      "required": ["id", "type", "left", "top", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "shape", "image", "line", "group"] },
        "left": { "type": "number", "minimum": 0 },
        "top": { "type": "number", "minimum": 0 },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 },
        "z_index": { "type": "integer", "default": 0 },
        "text": { "type": "string" },
        "shape": { "type": "string" },
        "src": { "type": "string" },
        "x1": { "type": "number" },
        "y1": { "type": "number" },
        "x2": { "type": "number" },
        "y2": { "type": "number" },
        "style": {
          "type": "object",
          "additionalProperties": true
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/renderElement" }
        }
      }
    }
  }
}
