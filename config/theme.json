{
  "meta": {
    "theme_name": "ai_report_v2",
    "version": "2.0",
    "description": "HTML to PPT dual-mode theme",
    "language": "zh-CN"
  },

  "slide": {
    "width_inch": 13.333,
    "height_inch": 7.5,
    "ratio": "16:9",
    "background_color": [255, 255, 255]
  },

  "prototype": {
    "html_canvas_width_px": 1600,
    "html_canvas_height_px": 900,
    "use_absolute_layout": true,
    "show_page_nav": true,
    "show_page_number": true
  },

  "calibration": {
    "px_to_inch_scale_x": 0.008333125,
    "px_to_inch_scale_y": 0.008333333,
    "font_size_bias_pt": 0.0,
    "line_height_bias": 1.0,
    "textbox_height_bias_inch": 0.00,
    "padding_left_bias_inch": 0.00,
    "padding_top_bias_inch": 0.00,
    "rounded_radius_scale": 1.0,
    "image_fit_default": "cover",
    "default_text_margin_left_inch": 0.03,
    "default_text_margin_right_inch": 0.03,
    "default_text_margin_top_inch": 0.01,
    "default_text_margin_bottom_inch": 0.01
  },

  "fonts": {
    "title": { "family_cn": "Microsoft YaHei", "family_en": "Aptos", "weight": "bold" },
    "subtitle": { "family_cn": "Microsoft YaHei", "family_en": "Aptos", "weight": "regular" },
    "body": { "family_cn": "Microsoft YaHei", "family_en": "Aptos", "weight": "regular" },
    "caption": { "family_cn": "Microsoft YaHei", "family_en": "Aptos", "weight": "regular" },
    "tag": { "family_cn": "Microsoft YaHei", "family_en": "Aptos", "weight": "regular" },
    "number": { "family_cn": "Aptos", "family_en": "Aptos", "weight": "regular" }
  },

  "font_sizes": {
    "cover_title": 28,
    "cover_subtitle": 16,
    "page_title": 23.5,
    "section_title": 20,
    "hero_title": 17.5,
    "hero_subtitle": 12.0,
    "hero_desc": 10.8,
    "card_title": 14.5,
    "card_subtitle": 10.2,
    "body_large": 13.0,
    "body": 11.5,
    "body_small": 10.5,
    "footer": 11.4,
    "tag": 10.0,
    "caption": 9.5,
    "page_number": 9.0
  },

  "colors": {
    "background": [255, 255, 255],
    "title": [28, 45, 74],
    "subtitle": [70, 84, 110],
    "text": [51, 51, 51],
    "subtext": [102, 112, 128],
    "caption": [130, 138, 150],
    "accent": [58, 110, 180],
    "accent_light": [232, 240, 250],
    "accent_soft": [241, 246, 252],
    "line": [210, 220, 232],
    "border": [220, 228, 238],
    "card_bg": [250, 251, 253],
    "panel_bg": [241, 246, 252],
    "tag_bg": [232, 240, 250],
    "success": [62, 136, 91],
    "warning": [215, 145, 39],
    "danger": [196, 76, 76],
    "white": [255, 255, 255],
    "black": [0, 0, 0]
  },

  "spacing": {
    "page_margin_left": 0.68,
    "page_margin_right": 0.68,
    "page_margin_top": 0.24,
    "page_margin_bottom": 0.30,
    "section_gap_small": 0.18,
    "section_gap": 0.28,
    "section_gap_large": 0.42,
    "card_gap_horizontal": 0.34,
    "card_gap_vertical": 0.22,
    "text_margin_left": 0.02,
    "text_margin_right": 0.02,
    "text_margin_top": 0.00,
    "text_margin_bottom": 0.00
  },

  "shape_style": {
    "radius_small": 0.06,
    "radius_medium": 0.10,
    "radius_large": 0.12,
    "border_width_pt": 1.0,
    "divider_width_pt": 1.2,
    "emphasis_line_width_pt": 1.35
  },

  "text_style": {
    "line_spacing": 1.0,
    "paragraph_spacing_pt": 0,
    "default_align": "left",
    "default_valign": "middle",
    "title_align": "left",
    "footer_align": "center",
    "card_title_align": "left",
    "card_subtitle_align": "left"
  },

  "effects": {
    "use_shadow": false,
    "shadow_level": "none",
    "use_transparency": true,
    "default_transparency": 0.0
  },

  "template_defaults": {
    "overview_cards": {
      "show_tag": true,
      "show_footer": true,
      "density": "normal",
      "hero_box": "compact",
      "card_style": "2x2",
      "card_count": 4,
      "visual_mode": "text_only"
    },
    "compare_2col": {
      "show_footer": true,
      "density": "normal",
      "visual_mode": "text_only"
    },
    "timeline": {
      "show_footer": true,
      "density": "normal",
      "visual_mode": "optional_visual"
    },
    "left_text_right_image": {
      "show_footer": true,
      "density": "normal",
      "visual_mode": "image_required"
    },
    "conclusion": {
      "show_footer": false,
      "density": "normal",
      "visual_mode": "text_only"
    },
    "cover": {
      "show_footer": false,
      "visual_mode": "background_needed"
    },
    "toc": {
      "show_footer": false,
      "visual_mode": "text_only"
    },
    "free_layout": {
      "show_footer": false,
      "visual_mode": "text_only"
    }
  }
}
